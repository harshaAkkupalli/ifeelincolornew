# ────────────────────────────────────────────────────────────────────────
# IFEELINCOLOR — backend environment template
#   Copy to `.env` and fill in the values your deployment actually uses.
#   Do NOT commit `.env` to git.
# ────────────────────────────────────────────────────────────────────────

# ── Required: database ──────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=ifeelincolor

# ── Required: auth ──────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string

# Default admin account that gets seeded on first boot.
ADMIN_EMAIL=admin@ifeelincolor.com
ADMIN_PASSWORD=Admin@123!

# ── CORS — comma-separated list of allowed origins ──────────────────────
CORS_ORIGINS=*

# ────────────────────────────────────────────────────────────────────────
# AI provider — pick ONE of the following four keys. The backend picks
# the first one it finds, in this order: OPENAI → ANTHROPIC → GOOGLE →
# EMERGENT. If you set `AI_DEFAULT_PROVIDER` it forces that choice.
#
# Every AI feature in the app — Email Templates (AI Generate), AI Follow-up
# messages, AI Coach, AI Recommendations, etc. — routes through the same
# adapter, so configuring ANY ONE of these keys turns on AI for the
# entire app.
# ────────────────────────────────────────────────────────────────────────

# Option 1 — OpenAI (recommended)
# OPENAI_API_KEY=sk-...

# Option 2 — Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 3 — Google AI Studio (Gemini)  ← easiest free tier
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_GENAI_API_KEY=AIza...

# Option 4 — Emergent Universal Key (only if you have one)
# EMERGENT_LLM_KEY=sk-emergent-...

# Optional pins
# AI_DEFAULT_PROVIDER=google
# AI_DEFAULT_MODEL=gemini-2.0-flash

# ── Google Maps (Places autocomplete + Nearby search) ───────────────────
# GOOGLE_MAPS_API_KEY=AIza...

# ── Razorpay (admin configures via UI; these are fallback env keys) ─────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Outbound email (optional — used for password reset & template send) ─
# GMAIL_SMTP_USER=
# GMAIL_APP_PASSWORD=
# SENDGRID_API_KEY=
